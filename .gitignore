# --- Sistema Operacional e Editores ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# --- Logs e Dados Sensíveis (Crítico para Privacidade) ---
# Garante que nenhum dado de simulação ou log acidental seja commitado
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Dependências (Caso use npm/yarn no futuro) ---
node_modules/
package-lock.json
yarn.lock

# --- Build e Distribuição (Se houver minificação futura) ---
dist/
build/
*.min.js.map

# --- Arquivos de Ambiente ---
.env
.env.local
.env.*.local

# --- Testes de Cobertura  ---
coverage/

# --- Documentos Temporários ---
# Ignora rascunhos que não fazem parte da docs final
docs/*.tmp
docs/*.bak