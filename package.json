{
  "name": "projeto-fgts",
  "version": "2.0.0",
  "description": "Simulador de FGTS e rescisão trabalhista — Projeto de Extensão UNINTER (TypeScript + DDD)",
  "type": "module",
  "main": "src/main.ts",
  "scripts": {
    "dev": "vite src",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --outDir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.{ts,html,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css}\"",
    "prepare": "husky"
  },
  "keywords": [
    "fgts",
    "clt",
    "trabalhista",
    "simulador",
    "brasil",
    "typescript",
    "ddd"
  ],
  "author": "AndersonTavares0",
  "license": "MIT",
  "dependencies": {
    "decimal.js": "^10.4.3",
    "lucide": "^1.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.6.1",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "husky": "^9.0.0",
    "jsdom": "^24.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{ts,html,css}": [
      "prettier --write"
    ]
  }
}
